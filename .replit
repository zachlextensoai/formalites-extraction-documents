modules = ["nodejs-20", "python-3.12"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[nix]
channel = "stable-25_05"
packages = ["tesseract", "poppler-utils", "tesseract4"]

[deployment]
build = ["sh", "-c", "cd frontend && npm install && npm run build"]
run = ["sh", "-c", "bash start-prod.sh"]
deploymentTarget = "autoscale"
